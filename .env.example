# ── Copilot Sessions Auth Config ──
# All three variables are required. The server will not start without them.

# Azure AD / Microsoft Entra tenant ID
AUTH_TENANT_ID=your-tenant-id-here

# Azure AD app registration client ID
AUTH_CLIENT_ID=your-client-id-here

# Email/UPN of the single allowed user (case-insensitive)
AUTH_ALLOWED_USER=you@example.com

# ── Optional ──
# PORT=3847
# COPILOT_MODEL=claude-sonnet-4-5
# COPILOT_CWD=C:\your\project
